# Copy to .env (gitignored). Defaults below = full_run_002 digital mode.
# run_mac.sh writes this automatically if .env is missing.

MODEL_BACKEND=ssl_aasist
AUTH_THRESHOLD=0.49
LOCAL_SSL_MODEL_DIR=models/ssl_aasist
LOCAL_SSL_WEIGHTS_PATH=training_runs/full_run_002/best_head.pth
CALL_CHANNEL_MODE=false

# Persistence for analysis outputs. "mongo" stores call records in MongoDB and
# auto-falls back to JSON (data/call_log.json) if the server is unreachable.
# Use "json" to force file-based storage.
PERSISTENCE_BACKEND=mongo
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=deepfake_fraud
MONGODB_COLLECTION=calls

# Optional: include FoR-style short clips (<2s). Default gate is 2.0.
# AUDIO_MIN_DURATION_SEC=1.0
